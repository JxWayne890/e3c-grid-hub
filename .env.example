SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase Project Settings → API → JWT Settings → JWT Secret. Required for
# minting per-user JWTs the MCP server uses to call Supabase under RLS.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
RESEND_API_KEY=your-resend-api-key
OPENCLAW_URL=https://your-openclaw-instance.hstgr.cloud
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_DEVICE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
OPENCLAW_DEVICE_ID=your-app-prod-001
# Shared secret OpenClaw sends as `x-mcp-secret` on every MCP request.
# Generate: openssl rand -hex 32 (must be >=32 chars)
MCP_SHARED_SECRET=replace-me-with-openssl-rand-hex-32
# HMAC key used to sign the per-chat context token embedded in the system prompt.
# Generate: openssl rand -hex 32 (must be >=32 chars)
MCP_CONTEXT_SIGNING_KEY=replace-me-with-openssl-rand-hex-32
APP_URL=http://localhost:3000
VITE_API_URL=https://api-e3c.srv1568356.hstgr.cloud
